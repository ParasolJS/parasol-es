{
  "name": "parasol-es",
  "version": "1.0.2",
  "description": "ES6 module for interactive visualization of multi-objective optimization problems, based on d3-v5 and parcoords-es modules",
  "main": "dist/parasol.js",
  "module": "dist/parasol.esm.js",
  "jsnext:main": "dist/parasol.esm.js",
  "style": "dist/parcoords.css",
  "directories": {
    "lib": "lib"
  },
  "nyc": {
    "require": [
      "@babel/register"
    ],
    "reporter": [
      "lcov",
      "text"
    ],
    "sourceMap": false,
    "instrument": false
  },
  "scripts": {
    "lint": "eslint src",
    "lint:fix": "eslint --fix src",
    "prettier": "prettier --single-quote --trailing-comma es5 --write \"{src,__{demo,dist}__}/**/*.js\"",
    "dev": "rollup -c rollup.config.dev.mjs -w",
    "build": "rollup -c rollup.config.mjs",
    "docs": "jsdoc src -r -d docs"
  },
  "files": [
    "src",
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ParasolJS/parasol.git"
  },
  "keywords": [
    "es6",
    "d3v5",
    "Parasol",
    "parallel coordinates",
    "multiobjective optimization",
    "visualization"
  ],
  "author": "Josh Jacobson <joshuah.jacobson@gmail.com> (http://joshhjacobson.github.io)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ParasolJS/parasol-es/issues"
  },
  "homepage": "https://github.com/ParasolJS/parasol-es#readme",
  "devDependencies": {
    "@babel/cli": "^7.24.0",
    "@babel/core": "^7.24.0",
    "@babel/plugin-transform-runtime": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/register": "^7.23.7",
    "@babel/runtime": "^7.24.0",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.0",
    "jsdoc": "^4.0.2",
    "livereload": "^0.9.3",
    "mocha": "^10.4.0",
    "prettier": "^3.2.5",
    "rollup": "^4.13.0",
    "rollup-plugin-livereload": "^2.0.5",
    "rollup-plugin-postcss": "^4.0.2",
    "rollup-plugin-serve": "^3.0.0"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5"
  },
  "engines": {
    "node": ">=12"
  },
  "dependencies": {
    "d3": "^7.0.0",
    "d3-dsv": "^3.0.0",
    "file-saver": "^1.3.8",
    "flatpickr": "^4.5.2",
    "jquery": "^3.3.1",
    "lodash-es": "^4.17.11",
    "ml-distance-euclidean": "^2.0.0",
    "ml-kmeans": "^4.2.1",
    "ml-xsadd": "^2.0.0",
    "parcoord-es": "github:jrkasprzyk/parcoords-es#bb2c9646f964020fcd2b8f821eace3e228c96143",
    "random": "^2.0.12",
    "slickgrid-es6": "^3.0.1"
  }
}
